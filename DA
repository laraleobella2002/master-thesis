import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as ticker

# Load the data
df = pd.read_csv("data_357_session_01.csv")

# Get all unique conditions from the 'label' column
conditions = df["label"].unique()

# Create a figure with a 2x2 grid of subplots
fig, axes = plt.subplots(nrows=2, ncols=2, figsize=(16, 10))
axes = axes.flatten()  # Flatten the 2x2 matrix into a 1D list for easy looping

# Optional: Different colors for each condition
colors = ['blue', 'green', 'red', 'purple']

for i, condition in enumerate(conditions):
    # Filter the subset for the current condition
    subset = df[df["label"] == condition]
    
    ax = axes[i]
    ax.plot(subset["trials"], subset["offset"].abs(), marker="o", linestyle="-", color=colors[i % len(colors)])
    
    # Set minor locators
    ax.xaxis.set_minor_locator(ticker.AutoMinorLocator(10))
    
    # Labels and Titles
    ax.set_title(condition)
    ax.set_xlabel("Trial")
    ax.set_ylabel("Absolute Offset")

# Adjust the layout so plots don't overlap
plt.tight_layout()
plt.show()
