import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv('data_nawal22_session_01.csv')

correct_df = df[df['accuracy'] == 'correct'].copy()
correct_df['abs_offset'] = correct_df['offset'].abs()
min_offset_per_block = correct_df.groupby('label')['abs_offset'].min()

pd.set_option('display.precision', 30)
print(min_offset_per_block)
print("Minimum Offsets:")

Binocular_Standard = min_offset_per_block.get('Block 1: Binocular_Standard')
Binocular_Crowded  = min_offset_per_block.get('Block 2: Binocular_Crowded')
Monocular_Standard = min_offset_per_block.get('Block 3: Monocular_Standard')
Monocular_Crowded  = min_offset_per_block.get('Block 4: Monocular_Crowded')

plt.figure(figsize=(8, 7))

plt.scatter(Binocular_Standard, Binocular_Crowded, color='lightblue', s=150, label='Binocular')

plt.scatter(Monocular_Standard, Monocular_Crowded, color='pink', s=150, label='Monocular')

plt.text(Binocular_Standard, Binocular_Standard, '  Binocular', fontsize=12)
plt.text(Monocular_Standard, Monocular_Crowded, '  Monocular', fontsize=12)

max_val = max(Binocular_Standard, Binocular_Crowded, Monocular_Standard, Monocular_Crowded)
axis_limit = max_val * 1.2 if max_val > 0 else 0.1 

# Add a diagonal dashed line (y=x) as a reference. 
# Points above this line mean Crowded > Standard.
# k here is for black 
plt.plot([0, axis_limit], [0, axis_limit], 'k--', alpha=1, label='Equal Thresholds (y=x)')

plt.xlim(0, axis_limit)
plt.ylim(0, axis_limit)
plt.xlabel('Smallest Absolute Offset (Standard)', fontsize=12)
plt.ylabel('Smallest Absolute Offset (Crowded)', fontsize=12)
plt.title('Vernier Thresholds: Crowded vs Standard', fontsize=14)

plt.grid(True, linestyle='--', alpha=0.6)
plt.legend(loc='upper left')
plt.tight_layout() 
plt.savefig('vernier_results.png', dpi=300, bbox_inches='tight')
plt.show()
