import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from scipy.optimize import curve_fit
import psignifit as ps

data = np.array([[0.0010, 45.0000, 90.0000], [0.0015, 50.0000, 90.0000],
                 [0.0020, 44.0000, 90.0000], [0.0025, 44.0000, 90.0000],
                 [0.0030, 52.0000, 90.0000], [0.0035, 53.0000, 90.0000],
                 [0.0040, 62.0000, 90.0000], [0.0045, 64.0000, 90.0000],
                 [0.0050, 76.0000, 90.0000], [0.0060, 79.0000, 90.0000],
                 [0.0070, 88.0000, 90.0000], [0.0080, 90.0000, 90.0000],
                 [0.0100, 90.0000, 90.0000]])

res = ps.psignifit(data, sigmoid='norm', experiment_type='2AFC')

# Load data and prepare columns
df = pd.read_csv('data_lala.csv')
df['offset_clean'] = np.round(df['offset'], decimals=4)
df['resp_right'] = (df['keys'] == "['right']").astype(int)

# Define logistic function
def logistic(x, alpha, beta):
    return 1 / (1 + np.exp(-beta * (x - alpha)))

# Set up the plot size
plt.figure(figsize=(11, 7))

# Get all unique block labels
labels = df['label'].unique()

# Generate a distinct color for each label using a colormap
colors = plt.cm.tab10(np.linspace(0, 1, len(labels)))

for i, label in enumerate(labels):
    # Filter the dataset for the current block
    subset = df[df['label'] == label]
    
    # Calculate proportions for this specific block
    grouped = subset.groupby('offset_clean')['resp_right'].agg(['mean', 'count']).reset_index()
    
    try:
        # Fit the logistic curve to the block's data
        popt, pcov = curve_fit(logistic, grouped['offset_clean'], grouped['mean'], p0=[0, 10], maxfev=10000)
        
        # Generate smooth points for the curve
        x_fit = np.linspace(grouped['offset_clean'].min(), grouped['offset_clean'].max(), 200)
        y_fit = logistic(x_fit, *popt)
        
        # Plot the fitted smooth curve as a line
        plt.plot(x_fit, y_fit, '-', color=colors[i], linewidth=2.5, label=f'{label}')
        
        # Plot the raw data points as dots (slightly transparent)
        plt.plot(grouped['offset_clean'], grouped['mean'], 'o', color=colors[i], markersize=6, alpha=0.5)
        
    except Exception as e:
        print(f"Could not fit curve for {label}: {e}")
        # Fallback: if data is too noisy for a curve fit, just connect the dots with a line
        plt.plot(grouped['offset_clean'], grouped['mean'], 'o-', color=colors[i], linewidth=2.5, label=f'{label} (Raw Data)')

# Add formatting and labels
plt.axhline(y=0.5, color='gray', linestyle='--') # 50% Threshold line

plt.xlabel('Offset', fontsize=12)
plt.ylabel('Proportion of "Right" Responses', fontsize=12)
plt.title('Psychometric Functions per Condition', fontsize=14, fontweight='bold')

# Put the legend outside the plot so it doesn't overlap lines
plt.legend(bbox_to_anchor=(1.02, 1), loc='upper left', borderaxespad=0.)

plt.grid(True, alpha=0.3)
plt.tight_layout() # Adjust layout so legend isn't cut off

# Save and visualize
plt.savefig('psychometric_functions_all.png')
