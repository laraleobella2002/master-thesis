#threshold JND from the curve 
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy.optimize import curve_fit

sns.set_theme(style="whitegrid", context="paper", font_scale=1.2)

df = pd.read_csv("data_nawal22_session_01.csv")

df['is_right'] = (df['keys'] == 'right').astype(int)

def psychometric_curve(x, alpha, beta):
    return 1 / (1 + np.exp(-beta * (x - alpha))) # sigmoid curve equation

blocks = df['label'].unique()

# Create a 2x2 grid. sharey=True keeps the Y-axis aligned across all plots
fig, axes = plt.subplots(2, 2, figsize=(14, 10), sharey=True)
axes = axes.flatten()

colors = sns.color_palette("deep", len(blocks))

for ax, block, color in zip(axes, blocks, colors):
        block_data = df[df['label'] == block]
    
    # Cleanly group by 'offset'
    summary = block_data.groupby('offset')['is_right'].agg(
        prob_right='mean', 
        trial_count='count'
    ).reset_index()
    
    x = summary['offset'].values
    y = summary['prob_right'].values
    sizes = summary['trial_count'].values
    
    # Fit the psychometric curve using SciPy
    try:
        popt, _ = curve_fit(psychometric_curve, x, y, p0=[0, 10], maxfev=10000)
        alpha, beta = popt
        
        # Calculate JND mathematically
        jnd = np.log(3) / beta
        
    except RuntimeError:
        alpha, beta = 0, 1 # Safe fallback if the fit fails
        jnd = np.log(3) / beta 
        
    # Scatter plot mapping 'sizes' automatically to the dot size
    sns.scatterplot(
        x=x, y=y, 
        size=sizes, sizes=(30, 250), 
        color=color, alpha=0.8, ax=ax, 
        legend=False, edgecolor="black"
    )
    
    # Generate smooth curve line
    x_smooth = np.linspace(x.min(), x.max(), 300)
    y_smooth = psychometric_curve(x_smooth, alpha, beta)
    
    # Plot curve and add calculated values to the legend
    ax.plot(x_smooth, y_smooth, color=color, linewidth=3, 
            label=f"PSE (α) = {alpha:.3f}\nSlope (β) = {beta:.1f}\nJND = {jnd:.3f}")
    
    # Add background guide lines for 50%, 75%, and 25% marks
    ax.axhline(0.5, color='gray', linestyle='--', alpha=0.6, zorder=0)
    ax.axhline(0.75, color='lightgray', linestyle=':', alpha=0.6, zorder=0)
    ax.axhline(0.25, color='lightgray', linestyle=':', alpha=0.6, zorder=0)
    
    # Vertical lines for the PSE and the exact JND boundaries on the X-axis
    ax.axvline(alpha, color='gray', linestyle='--', alpha=0.6, zorder=0)
    
    x_25 = alpha - np.log(3)/beta
    x_75 = alpha + np.log(3)/beta
    ax.axvline(x_25, color='lightgray', linestyle=':', alpha=0.6, zorder=0)
    ax.axvline(x_75, color='lightgray', linestyle=':', alpha=0.6, zorder=0)
    
    ax.set_title(block, fontsize=14, fontweight='bold', pad=10)
    ax.set_xlabel("Offset (Stimulus Intensity)", fontsize=12)
    ax.set_ylabel('P(Response = "Right")', fontsize=12)
    ax.legend(loc="lower right", frameon=True, shadow=True)
    ax.set_ylim(-0.05, 1.05)

sns.despine() # Removes the top and right borders for a cleaner look
plt.tight_layout()
plt.show()
